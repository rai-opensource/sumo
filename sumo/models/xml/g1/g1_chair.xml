<mujoco model="g1_chair">
  <include file="g1.xml"/>
  <include file="../objects/yellow_chair/yellow_chair_defs.xml"/>

  <asset>
    <material name="yellow_chair_semi_transparent" rgba="1 1 0 0.3"/>
  </asset>

  <worldbody>
    <body name="yellow_chair" pos="3 0 0">
      <joint name="yellow_chair_joint" type="free" limited="false"/>
      <inertial pos="0 0.06 0.26" mass="16.58" diaginertia="0.25 0.25 0.25"/>

      <geom name="yellow_chair_visual" class="yellow_chair_visual" type="mesh" mesh="yellow_chair_mesh"/>
      <geom name="yellow_chair_back" type="mesh" class="yellow_chair_collision" priority="6" mesh="yellow_chair_back" friction="0.3 0.2 0.2"/>
      <geom name="yellow_chair_seat" type="mesh" class="yellow_chair_collision" priority="6" mesh="yellow_chair_seat" friction="0.3 0.2 0.2"/>
      <geom name="yellow_chair_rollers" type="cylinder" size="0.20 0.1" pos="0 0 0.09" class="yellow_chair_collision" priority="8" friction="0.05 0.2 0.2"/>

      <site name="trace_yellow_chair" pos="0 0 0" size="0.01"/>
      <site name="site_chair_object" pos="0 0.06 0.4" size="0.01"/>
    </body>
  </worldbody>

  <sensor>
    <framepos name="trace_pelvis" objtype="site" objname="site_pelvis"/>
    <framepos name="trace_yellow_chair" objtype="site" objname="trace_yellow_chair"/>
    <framepos name="trace_left_palm" objtype="site" objname="left_palm"/>
    <framepos name="trace_right_palm" objtype="site" objname="right_palm"/>
    <framezaxis name="chair_z_axis" objtype="site" objname="site_chair_object"/>
  </sensor>
</mujoco>
